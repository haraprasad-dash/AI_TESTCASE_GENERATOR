# TestGen AI Agent - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Application Settings
# ============================================
APP_PORT=8000
APP_HOST=127.0.0.1
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE=20
SESSION_TIMEOUT=60

# ============================================
# JIRA Configuration
# ============================================
JIRA_BASE_URL=https://your-instance.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_DEFAULT_PROJECT=PROJ

# ============================================
# OpenText ValueEdge Configuration
# ============================================
VALUEEDGE_BASE_URL=https://valueedge.yourcompany.com
VALUEEDGE_CLIENT_ID=your-client-id
VALUEEDGE_CLIENT_SECRET=your-client-secret
VALUEEDGE_SHARED_SPACE_ID=1001

# ============================================
# LLM Configuration - Groq (Cloud)
# ============================================
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
GROQ_DEFAULT_TEMPERATURE=0.2

# ============================================
# LLM Configuration - Ollama (Local)
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1

# ============================================
# Export Settings
# ============================================
EXPORT_DEFAULT_FORMAT=markdown
EXPORT_AUTO_SAVE=true
EXPORT_OUTPUT_DIRECTORY=./outputs

# ============================================
# Template Paths
# ============================================
TEST_PLAN_TEMPLATE_PATH=./templates/test_plan_generation.md
TEST_CASE_TEMPLATE_PATH=./templates/test_case_generation.md
